{
  "name": "inversora-api",
  "version": "0.0.1",
  "description": "",
  "author": "Ivan Romero",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "overrides": {
    "@hono/node-server": "1.19.13"
  },
  "scripts": {
    "build": "prisma generate && nest build",
    "postinstall": "prisma generate",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:ci": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node -r ./scripts/preload-env.cjs node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "node -r ./scripts/preload-env.cjs node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:debug": "node -r ./scripts/preload-env.cjs node_modules/@nestjs/cli/bin/nest.js start --debug --watch",
    "start:prod": "node -r ./scripts/preload-env.cjs dist/main.js",
    "start:local": "node scripts/run-with-profile.cjs local nest start --watch",
    "start:qa": "node scripts/run-with-profile.cjs qa nest start --watch",
    "start:pro": "node scripts/run-with-profile.cjs pro nest start --watch",
    "start:pro:local": "node scripts/start-pro-local.cjs",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:ci": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:ci": "jest --coverage --ci",
    "typecheck": "tsc --noEmit",
    "typecheck:build": "tsc -p tsconfig.build.json --noEmit",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "jest --config ./test/jest-integration.json --runInBand",
    "test:integration:ci": "jest --config ./test/jest-integration.json --runInBand --ci",
    "test:e2e:ci": "jest --config ./test/jest-e2e.json --runInBand --ci",
    "db:up": "docker compose --env-file env/local.env up -d postgres",
    "db:down": "docker compose --env-file env/local.env down",
    "db:logs": "docker compose --env-file env/local.env logs -f postgres",
    "agent:up": "docker compose --env-file env/local.env --profile agent up -d assistant-agent",
    "agent:down": "docker compose --env-file env/local.env --profile agent stop assistant-agent",
    "db:validate": "node scripts/validate-db-connection.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "node -r ./scripts/preload-env.cjs node_modules/prisma/build/index.js migrate dev",
    "prisma:migrate:deploy": "node -r ./scripts/preload-env.cjs node_modules/prisma/build/index.js migrate deploy",
    "prisma:studio": "node -r ./scripts/preload-env.cjs node_modules/prisma/build/index.js studio",
    "prisma:validate": "prisma validate && node -r ./scripts/preload-env.cjs scripts/validate-prisma-connection.mjs",
    "fmp:capture-fixtures": "node --env-file=.env scripts/capture-fmp-fixtures.mjs",
    "sync:run": "node scripts/ensure-prisma-client.cjs && node -r ./scripts/preload-env.cjs -r ts-node/register -r tsconfig-paths/register src/cli/run-fund-sync.ts",
    "sync:batches": "node scripts/ensure-prisma-client.cjs && node -r ./scripts/preload-env.cjs -r ts-node/register -r tsconfig-paths/register src/cli/run-etf-catalog-batches.ts",
    "sync:prices:batches": "node scripts/ensure-prisma-client.cjs && node scripts/run-cli-with-dotenv.mjs src/cli/run-price-sync-batches.ts",
    "sync:production": "node scripts/ensure-prisma-client.cjs && node scripts/run-cli-with-dotenv.mjs src/cli/run-production-sync.ts",
    "sync:postdeploy": "node scripts/ensure-prisma-client.cjs && node scripts/run-cli-with-dotenv.mjs src/cli/run-production-sync.ts --skip-metadata",
    "sync:reconcile-visibility": "node scripts/ensure-prisma-client.cjs && node -r ./scripts/preload-env.cjs -r ts-node/register -r tsconfig-paths/register src/cli/run-catalog-visibility-reconcile.ts",
    "sync:backfill-themes": "node scripts/ensure-prisma-client.cjs && node -r ./scripts/preload-env.cjs -r ts-node/register -r tsconfig-paths/register src/cli/run-fund-theme-backfill.ts",
    "sync:returns:backfill": "node scripts/ensure-prisma-client.cjs && node -r ./scripts/preload-env.cjs -r ts-node/register -r tsconfig-paths/register src/cli/run-returns-backfill.ts",
    "sync:backfill-benchmarks": "node scripts/ensure-prisma-client.cjs && node -r ./scripts/preload-env.cjs -r ts-node/register -r tsconfig-paths/register src/cli/backfill-fund-benchmarks.ts",
    "sync:score": "node scripts/ensure-prisma-client.cjs && node -r ./scripts/preload-env.cjs -r ts-node/register -r tsconfig-paths/register src/cli/run-fund-sync.ts --no-metadata --no-prices --no-composition --scoring",
    "sync:score:pro": "node scripts/run-with-profile.cjs pro npm run sync:score",
    "sync:reconcile-visibility:pro": "node scripts/run-with-profile.cjs pro npm run sync:reconcile-visibility",
    "sync:local": "node scripts/run-with-profile.cjs local node scripts/ensure-prisma-client.cjs && node scripts/run-with-profile.cjs local node -r ./scripts/preload-env.cjs -r ts-node/register -r tsconfig-paths/register src/cli/run-fund-sync.ts --symbols SPY --no-composition",
    "sync:qa": "node scripts/run-with-profile.cjs qa node scripts/ensure-prisma-client.cjs && node scripts/run-with-profile.cjs qa node -r ./scripts/preload-env.cjs -r ts-node/register -r tsconfig-paths/register src/cli/run-fund-sync.ts --symbols SPY --no-composition",
    "sync:pro": "node scripts/run-with-profile.cjs pro node scripts/ensure-prisma-client.cjs && node scripts/run-with-profile.cjs pro node -r ./scripts/preload-env.cjs -r ts-node/register -r tsconfig-paths/register src/cli/run-fund-sync.ts --symbols SPY --no-composition",
    "test:env": "node --test scripts/load-env.spec.cjs",
    "security:verify-local": "node scripts/verify-local-security.cjs",
    "security:check-encoding": "node scripts/check-mojibake.cjs",
    "db:count-funds": "node scripts/count-funds.mjs",
    "db:quarantine-breakdown": "node scripts/quarantine-breakdown.mjs",
    "prepare": "node scripts/prepare-husky.cjs"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nestjs": "^10.65.0",
    "@sentry/node": "^10.65.0",
    "axios": "^1.18.1",
    "helmet": "^8.3.0",
    "ioredis": "^5.11.1",
    "openai": "^6.46.0",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.28",
    "@types/express": "^5.0.0",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.63.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.ts",
      "!**/*.module.ts",
      "!**/main.ts",
      "!**/instrument.ts",
      "!**/cli/**",
      "!**/*.dto.ts",
      "!**/*.controller.ts",
      "!**/decorators/**",
      "!**/schedulers/**",
      "!**/swagger.config.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
