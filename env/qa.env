# Committed defaults for INVERSORA_ENV=qa.
# Put DATABASE_URL and secrets in `.env` / `.env.qa` (gitignored).
APP_ENV=qa
NODE_ENV=production

FMP_DATA_SOURCE=live
FMP_SAVE_FIXTURES=false

SYNC_SCHEDULER_ENABLED=false
SYNC_ETF_LIST_DISCOVERY=false
SYNC_COMPOSITION_ENABLED=false

ADMIN_SYNC_ENABLED=true
ADMIN_CATALOG_ENABLED=true

ASSISTANT_ENABLED=false
