# Committed defaults for INVERSORA_ENV=local (Docker Postgres + mock FMP).
# These keys are for isolated local development only. Do not reuse in qa/pro.
APP_ENV=local
NODE_ENV=development

POSTGRES_USER=inversora
POSTGRES_PASSWORD=change-me-local-postgres
POSTGRES_DB=inversora
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://inversora:change-me-local-postgres@localhost:5432/inversora

FMP_DATA_SOURCE=mock
FMP_SAVE_FIXTURES=false
SWAGGER_ENABLED=true

SYNC_SCHEDULER_ENABLED=false
SYNC_ETF_LIST_DISCOVERY=false
SYNC_COMPOSITION_ENABLED=false

ADMIN_SYNC_ENABLED=true
ADMIN_CATALOG_ENABLED=true
ADMIN_API_KEY=change-me-local-admin-key

ASSISTANT_ENABLED=true
ASSISTANT_RUNTIME=python-agent
ASSISTANT_AGENT_BASE_URL=http://localhost:8001
ASSISTANT_AGENT_TIMEOUT_MS=30000
ASSISTANT_INTERNAL_API_KEY=change-me-local-sora-internal
ASSISTANT_AGENT_API_KEY=change-me-local-agent-key-16
SORA_BACKEND_BASE_URL=http://localhost:3000
SORA_INTERNAL_API_KEY=change-me-local-sora-internal
SORA_AGENT_PORT=8001
