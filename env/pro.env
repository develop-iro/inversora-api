# Committed defaults for INVERSORA_ENV=pro.
# Put DATABASE_URL and secrets in `.env` / `.env.pro` (gitignored).
APP_ENV=pro
NODE_ENV=production

FMP_DATA_SOURCE=live
FMP_SAVE_FIXTURES=false

SYNC_SCHEDULER_ENABLED=true
SYNC_ETF_LIST_DISCOVERY=false
SYNC_COMPOSITION_ENABLED=false

ADMIN_SYNC_ENABLED=false
ADMIN_CATALOG_ENABLED=false

ASSISTANT_ENABLED=false
