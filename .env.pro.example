# Production API profile
# Copy to .env.pro (or inject via your host secrets manager) and fill real values.

APP_ENV=pro

PORT=3000
# NODE_ENV is derived from APP_ENV when unset (production for pro)

# PostgreSQL — production database
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=
POSTGRES_PORT=5432
DATABASE_URL=

# FMP — live data required for pro (validated at startup)
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com
# FMP_DATA_SOURCE=live
# FMP_SAVE_FIXTURES=false

# CORS — production Expo / web clients only
CORS_ORIGINS=

# Scheduled sync — enabled by default on pro when unset
# SYNC_SCHEDULER_ENABLED=true
SYNC_CRON_EXPRESSION=0 6 * * *
SYNC_FUND_SYMBOLS=
SYNC_ETF_LIST_DISCOVERY=false
SYNC_DISCOVERY_LIMIT=50
SYNC_COMPOSITION_ENABLED=false

# Admin HTTP surfaces — disabled by default on pro
# ADMIN_SYNC_ENABLED=false
# ADMIN_CATALOG_ENABLED=false
# Set explicitly only for break-glass ops; requires a strong ADMIN_API_KEY
# ADMIN_API_KEY=

# Assistant
ASSISTANT_ENABLED=false
ASSISTANT_RUNTIME=nestjs
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ASSISTANT_INTERNAL_API_KEY=
ASSISTANT_AGENT_API_KEY=

# Security
SWAGGER_ENABLED=false
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120
THROTTLE_ASSISTANT_LIMIT=30
# THROTTLE_REDIS_URL=

# Brandfetch logos
BRANDFETCH_CLIENT_ID=
