# Server
PORT=3000

# Deployment profile selector (see env/*.env committed defaults).
# Priority: INVERSORA_ENV → APP_ENV → ENV. Aliases: ei/dev → local, staging → qa, prod → pro.
# Examples:
#   INVERSORA_ENV=local   → Docker Postgres + mock FMP (env/local.env)
#   INVERSORA_ENV=qa      → staging defaults (env/qa.env) + secrets in .env.qa
#   INVERSORA_ENV=pro     → production defaults (env/pro.env) + secrets in .env.pro
#   npm run start:qa / start:pro — API local con BD remota + FMP live (no Docker ni mock)
INVERSORA_ENV=local

# Optional debug log when loading env files:
# INVERSORA_ENV_DEBUG=true

NODE_ENV=development

# CORS — Expo web clients (empty = localhost defaults in dev)
CORS_ORIGINS=

# --- Secrets and personal overrides (keep in this gitignored file) ---

# Financial Modeling Prep
FMP_API_KEY=your-fmp-api-key
FMP_BASE_URL=https://financialmodelingprep.com

# QA/Pro database URLs belong in `.env.qa` / `.env.pro` (gitignored), not here.
# Local DATABASE_URL comes from env/local.env when INVERSORA_ENV=local.

# Admin (local default in env/local.env; override for remote profiles)
ADMIN_API_KEY=local-dev-admin-key

# SORA assistant (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ASSISTANT_INTERNAL_API_KEY=local-sora-internal-key

# Brandfetch Logo API (optional)
BRANDFETCH_CLIENT_ID=1idFIPVa2ymBOeqsfgS

# Optional Python SORA agent
SORA_AGENT_PORT=8001
OPENAI_AGENT_MODEL=gpt-4o-mini
SORA_BACKEND_BASE_URL=http://host.docker.internal:3000
SORA_INTERNAL_API_KEY=local-sora-internal-key
