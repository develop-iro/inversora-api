# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (Docker Compose)
POSTGRES_USER=inversora
POSTGRES_PASSWORD=inversora
POSTGRES_DB=inversora
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Connection string (Prisma and other database clients)
DATABASE_URL=postgresql://inversora:inversora@localhost:5432/inversora

# Outbound HTTP client defaults
HTTP_CLIENT_TIMEOUT_MS=10000
HTTP_CLIENT_MAX_RETRIES=3
HTTP_CLIENT_RETRY_DELAY_MS=500

# Financial Modeling Prep
FMP_API_KEY=your-fmp-api-key
FMP_BASE_URL=https://financialmodelingprep.com
# mock = use committed fixtures (default, no API quota used)
# live = call FMP API directly (use sparingly: 200 calls/day on free tier)
FMP_DATA_SOURCE=mock
# Set to true only when intentionally refreshing fixtures from live API
FMP_SAVE_FIXTURES=false
