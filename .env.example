# Server
PORT=3000
NODE_ENV=development
# Comma-separated browser origins for Expo web (scheme://host:port).
# Empty in development = localhost:8081 and :19006 defaults (see docs/cors-and-expo-client.md).
# Required in production/staging when testing Expo web against the API.
# CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
CORS_ORIGINS=

# PostgreSQL (Docker Compose)
POSTGRES_USER=inversora
POSTGRES_PASSWORD=inversora
POSTGRES_DB=inversora
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Connection string (Prisma and other database clients)
DATABASE_URL=postgresql://inversora:inversora@localhost:5432/inversora

# Outbound HTTP client defaults
HTTP_CLIENT_TIMEOUT_MS=10000
HTTP_CLIENT_MAX_RETRIES=3
HTTP_CLIENT_RETRY_DELAY_MS=500

# Financial Modeling Prep
FMP_API_KEY=your-fmp-api-key
FMP_BASE_URL=https://financialmodelingprep.com
# mock = use committed fixtures (default, no API quota used)
# live = call FMP API directly (use sparingly: 200 calls/day on free tier)
FMP_DATA_SOURCE=mock
# Set to true only when intentionally refreshing fixtures from live API
FMP_SAVE_FIXTURES=false

# Scheduled fund synchronization
SYNC_SCHEDULER_ENABLED=false
# Daily at 06:00 UTC
SYNC_CRON_EXPRESSION=0 6 * * *
# Comma-separated tickers; leave empty to sync all persisted funds
SYNC_FUND_SYMBOLS=
# Merge index-tracking US ETFs from FMP etf-list (plus curated UCITS when enabled)
SYNC_ETF_LIST_DISCOVERY=false
# Max etf-list symbols processed per discovery run (Starter: batch in chunks of 50)
SYNC_DISCOVERY_LIMIT=50
# Holdings/composition requires FMP plan above Starter
SYNC_COMPOSITION_ENABLED=false

# Manual admin sync (development / QA)
# Enable POST /admin/sync and npm run sync:run
ADMIN_SYNC_ENABLED=true
# Enable GET/PATCH /admin/funds catalog visibility management
ADMIN_CATALOG_ENABLED=true
# Minimum 8 characters; required when ADMIN_SYNC_ENABLED or ADMIN_CATALOG_ENABLED is true
ADMIN_API_KEY=local-dev-admin-key

# SORA assistant (OpenAI — server-side only)
ASSISTANT_ENABLED=false
ASSISTANT_RUNTIME=nestjs
# Used when ASSISTANT_RUNTIME=python-agent
ASSISTANT_AGENT_BASE_URL=http://localhost:8001
ASSISTANT_AGENT_TIMEOUT_MS=10000
# Shared secret for Python agent -> NestJS read-only tools
ASSISTANT_INTERNAL_API_KEY=local-sora-internal-key
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ASSISTANT_PROMPT_VERSION=sora-v1
ASSISTANT_CACHE_TTL_DAYS=90

# Optional Python runtime for future SORA agent orchestration
SORA_AGENT_PORT=8001
OPENAI_AGENT_MODEL=gpt-4o-mini
SORA_BACKEND_BASE_URL=http://host.docker.internal:3000
SORA_INTERNAL_API_KEY=local-sora-internal-key
