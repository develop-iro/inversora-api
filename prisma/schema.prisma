generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// External data provider that supplied the fund metadata.
enum FundProvider {
  FINANCIAL_MODELING_PREP @map("financial-modeling-prep")
}

/// High-level fund classification used by Invesora.
enum FundCategory {
  INDEX @map("index")
}

/// Catalog visibility state controlling public API exposure (RN-05 / HU-37).
enum CatalogVisibility {
  VISIBLE     @map("visible")
  QUARANTINED @map("quarantined")
  BLOCKED     @map("blocked")
}

/// Exposure dimension used to group persisted allocation slices.
enum FundAllocationCategory {
  SECTORIAL        @map("sectorial")
  REGIONAL         @map("regional")
  COUNTRIES        @map("countries")
  ASSET_ALLOCATION @map("asset-allocation")
  CAPITALIZATION   @map("capitalization")
  PORTFOLIO        @map("portfolio")
}

/// Persisted index fund entity used as the main domain record in Invesora.
model Fund {
  id           String       @id @default(uuid())
  symbol       String
  isin         String?      @unique
  name         String
  provider     FundProvider
  category     FundCategory
  currency     String       @db.Char(3)
  benchmark     String?
  volatility    Decimal?     @db.Decimal(8, 4)
  drawdown      Decimal?     @db.Decimal(8, 4)
  ter           Decimal?     @db.Decimal(8, 4)
  aum           Decimal?     @db.Decimal(20, 2)
  per           Decimal?     @db.Decimal(10, 4)
  dividendYield Decimal?     @db.Decimal(8, 4)
  trackingError Decimal?     @db.Decimal(8, 4)
  riskLevel     Int?
  score              Decimal?           @db.Decimal(5, 2)
  /// Product badge shown on fund cards (Spanish MVP copy; not sourced from FMP).
  badge              String             @default("")
  /// Investment theme label for catalog cards (Spanish MVP copy).
  themeLabel         String             @default("")
  /// Editorial flag: fund is suitable for beginner investors.
  idealForBeginners  Boolean            @default(false)
  catalogVisibility  CatalogVisibility  @default(VISIBLE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  prices             FundPrice[]
  holdings           FundHolding[]
  allocations        FundAllocation[]
  catalogVisibilityAudits FundCatalogVisibilityAudit[]

  @@unique([symbol, provider])
  @@index([catalogVisibility])
  @@index([idealForBeginners])
  @@map("funds")
}

/// Audit trail for manual and automatic catalog visibility transitions.
model FundCatalogVisibilityAudit {
  id            String            @id @default(uuid())
  fundId        String
  previousState CatalogVisibility
  newState      CatalogVisibility
  reason        String
  actor         String            @default("system")
  createdAt     DateTime          @default(now())
  fund          Fund              @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([fundId, createdAt])
  @@map("fund_catalog_visibility_audits")
}

/// Individual position within a fund portfolio snapshot.
model FundHolding {
  id               String   @id @default(uuid())
  fundId           String
  asOf             DateTime @db.Date
  rank             Int
  asset            String?
  name             String
  isin             String?
  weightPercentage Decimal  @db.Decimal(8, 4)
  marketValue      Decimal? @db.Decimal(20, 2)
  sharesNumber     Decimal? @db.Decimal(20, 6)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  fund             Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@unique([fundId, asOf, rank])
  @@index([fundId, asOf])
  @@map("fund_holdings")
}

/// Weighted allocation slice within a fund exposure snapshot.
model FundAllocation {
  id        String                 @id @default(uuid())
  fundId    String
  asOf      DateTime               @db.Date
  category  FundAllocationCategory
  label     String
  weight    Decimal                @db.Decimal(8, 4)
  sortOrder Int                    @default(0)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  fund      Fund                   @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@unique([fundId, asOf, category, label])
  @@index([fundId, asOf, category])
  @@map("fund_allocations")
}

/// End-of-day price point persisted for fund performance charts.
model FundPrice {
  id            String   @id @default(uuid())
  fundId        String
  date          DateTime @db.Date
  open          Decimal  @db.Decimal(18, 6)
  high          Decimal  @db.Decimal(18, 6)
  low           Decimal  @db.Decimal(18, 6)
  close         Decimal  @db.Decimal(18, 6)
  volume        BigInt?
  change        Decimal? @db.Decimal(18, 6)
  changePercent Decimal? @db.Decimal(10, 6)
  vwap          Decimal? @db.Decimal(18, 6)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  fund          Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@unique([fundId, date])
  @@index([fundId, date])
  @@map("fund_prices")
}
