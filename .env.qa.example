# QA / staging API profile
# Copy to .env.qa (or merge into your deployment secrets) and fill real values.

APP_ENV=qa

PORT=3000
# NODE_ENV is derived from APP_ENV when unset (production for qa)

# PostgreSQL — staging database
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=
POSTGRES_PORT=5432
DATABASE_URL=

# FMP — live data required for qa (validated at startup)
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com
# FMP_DATA_SOURCE=live
# FMP_SAVE_FIXTURES=false

# CORS — Expo QA builds and staging web clients
CORS_ORIGINS=

# Scheduled sync — enable when staging cron is configured
SYNC_SCHEDULER_ENABLED=false
SYNC_CRON_EXPRESSION=0 6 * * *
SYNC_FUND_SYMBOLS=
SYNC_ETF_LIST_DISCOVERY=false
SYNC_DISCOVERY_LIMIT=50
SYNC_COMPOSITION_ENABLED=false

# Admin — enable for staging ops; requires ADMIN_API_KEY
ADMIN_SYNC_ENABLED=true
ADMIN_CATALOG_ENABLED=true
ADMIN_API_KEY=

# Assistant (optional on staging)
ASSISTANT_ENABLED=false
ASSISTANT_RUNTIME=nestjs
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Brandfetch logos
BRANDFETCH_CLIENT_ID=
